    <hasActivationRequired>false</hasActivationRequired>
    <label>NTO Portal Customer</label>
    <classAccesses>
        <apexClass>NTOOrderCardService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PortalCustomerController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <fieldPermissions>
        <field>NTO_Order__c.Contact__c</field>
